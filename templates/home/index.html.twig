{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block meta %}
	<meta name="description" content="Konvix Technology — Découvrez notre marketplace de produits technologiques : accessoires, électronique, pièces auto et plus. Livraison rapide, vendeurs vérifiés.">
	<meta name="robots" content="index, follow">
{% endblock %}

{% block og_title %}Konvix Technology — Marketplace technologique{% endblock %}
{% block og_description %}Découvrez notre marketplace de produits technologiques : accessoires, électronique, pièces auto et plus.{% endblock %}

{% block breadcrumb %}
    {% include '_partials/_breadcrumb.html.twig' %}
{% endblock %}

{% block body %}
	{# Carrousel hero #}
	{% include '_partials/_hero.html.twig' %}

	{# Breadcrumb sous le carrousel #}
	{% include '_partials/_breadcrumb.html.twig' %}

	{# Section produits en vedette #}
	{% if featuredProducts|length > 0 %}
		<section class="mt-5">
			<div class="d-flex justify-content-between align-items-center mb-3">
				<h2 class="fw-bold mb-0">Nouveautés</h2>
				<a href="{{ path('product_list') }}" class="btn btn-outline-primary btn-sm">
					Voir tous les produits <i class="bi bi-arrow-right ms-1"></i>
				</a>
			</div>
			<div class="row g-3">
				{% for product in featuredProducts %}
					<div class="col-6 col-sm-4 col-md-3">
						<div class="card h-100 shadow-sm border-0">
							<a href="{{ path('app_product_show', {id: product.id}) }}" class="text-decoration-none">
								<img
									src="/uploads/product_images/{{ product.imageFolder }}/{{ product.mainImage }}"
									class="card-img-top bg-white"
									alt="{{ product.name }}"
									style="height: 160px; object-fit: contain; padding: 0.5rem;"
									onerror="this.src='/images/placeholder.png'">
							</a>
							<div class="card-body d-flex flex-column p-3">
								<h6 class="card-title fw-semibold mb-1">{{ product.name }}</h6>
								<p class="text-muted small mb-1">{{ product.category ? product.category.name : '' }}</p>
								<p class="fw-bold text-danger mb-2">{{ product.price|number_format(2, '.', ' ') }} €</p>
								<a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-primary btn-sm mt-auto">
									Voir le produit
								</a>
							</div>
						</div>
					</div>
				{% endfor %}
			</div>
		</section>
	{% endif %}

	{# Section avantages #}
	<section class="mt-5 mb-3">
		<div class="row g-4 text-center">
			<div class="col-6 col-md-3">
				<div class="p-3">
					<i class="bi bi-truck fs-1 text-primary"></i>
					<h6 class="fw-bold mt-2">Livraison rapide</h6>
					<p class="text-muted small">Expédition sous 24-48h</p>
				</div>
			</div>
			<div class="col-6 col-md-3">
				<div class="p-3">
					<i class="bi bi-shield-check fs-1 text-success"></i>
					<h6 class="fw-bold mt-2">Vendeurs vérifiés</h6>
					<p class="text-muted small">Tous nos vendeurs sont validés</p>
				</div>
			</div>
			<div class="col-6 col-md-3">
				<div class="p-3">
					<i class="bi bi-arrow-counterclockwise fs-1 text-warning"></i>
					<h6 class="fw-bold mt-2">Retours faciles</h6>
					<p class="text-muted small">30 jours pour changer d'avis</p>
				</div>
			</div>
			<div class="col-6 col-md-3">
				<div class="p-3">
					<i class="bi bi-headset fs-1 text-danger"></i>
					<h6 class="fw-bold mt-2">Support client</h6>
					<p class="text-muted small">Disponible 7j/7</p>
				</div>
			</div>
		</div>
	</section>
{% endblock %}

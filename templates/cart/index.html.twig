{% extends 'base.html.twig' %}

{% block breadcrumb %}
	{% include '_partials/_breadcrumb.html.twig' %}
{% endblock %}

{% block body %}
	{% for label, messages in app.flashes %}
		{% for alert in alerts %}
			<div class="alert alert-danger">{{ alert }}</div>
		{% endfor %}
		{% for message in messages %}
			<div class="alert alert-{{ label == 'warning' ? 'warning' : (label == 'success' ? 'success' : 'info') }}">{{ message }}</div>
		{% endfor %}
	{% endfor %}
	<div class="container my-5">
		<h1>Mon panier</h1>
		{% if cart is empty %}
			<div class="alert alert-info">Votre panier est vide.</div>
		{% else %}
			<table class="table table-bordered table-hover mt-4">
				<thead class="table-light">
					<tr>
						<th>Produit</th>
						<th>Quantité</th>
						<th>Prix unitaire</th>
						<th>Total</th>
						<th>Action</th>
					</tr>
				</thead>
				<tbody>
					{% set total = 0 %}
					{% for item in cart %}
						<tr>
							<td>{{ item.product.name }}</td>
							<td>{{ item.quantity }}</td>
							<td>{{ item.product.price|number_format(2, ',', ' ') }}
								€</td>
							<td>{{ (item.product.price * item.quantity)|number_format(2, ',', ' ') }}
								€</td>
							<td>
								<a href="{{ path('cart_remove', {'id': item.product.id}) }}" class="btn btn-danger btn-sm">Retirer</a>
							</td>
						</tr>
						{% set total = total + (item.product.price * item.quantity) %}
					{% endfor %}
				</tbody>
			</table>
			<div class="row mt-4">
				<div class="col-md-7 col-12 mb-3 mb-md-0">
					<a href="{{ path('cart_clear') }}" class="btn btn-outline-danger">Vider le panier</a>
				</div>
				<div class="col-md-5 col-12">
					<form method="post" action="{{ path('cart_checkout') }}">
						<div class="card p-3 shadow-sm">
							<h5 class="mb-3">Choisissez votre mode de livraison</h5>
							<div class="alert alert-light border mb-3 py-2" style="font-size:0.95em;">
								Poids total expedition (avec enveloppe a bulles) :
								<span class="fw-bold">{{ shippingWeight|number_format(0, ',', ' ') }} g</span>
							</div>
							{% set selected = selectedTransporteur|default('') %}
							{% for t in transporteurs %}
								<div class="form-check mb-2">
									<input class="form-check-input" type="radio" name="transporteur" id="t_{{ t.id }}" value="{{ t.id }}" {% if selected == t.id %} checked {% endif %} {% if t.available is defined and not t.available %}disabled{% endif %}>
									<label class="form-check-label" for="t_{{ t.id }}">
										<span class="fw-bold">{{ t.name }}</span>
										<span class="badge bg-primary ms-2">{{ t.price|number_format(2, ',', ' ') }}
											€</span><br>
										<span class="text-muted" style="font-size:0.95em;">{{ t.desc }}</span>
									</label>
								</div>
							{% endfor %}
							<div class="mt-3">
								<div class="mb-2">Frais de livraison :
									<span class="fw-bold text-warning">{{ selectedFrais|number_format(2, ',', ' ') }}
										€</span>
								</div>
								{% if codePromo %}
									<div class="mb-2 text-success">
										<i class="bi bi-ticket"></i>
										Code promo appliqué :
										<span class="fw-bold">{{ codePromo.code }}</span>
									</div>
									<div class="mb-2">Réduction :
										<span class="fw-bold text-danger">-{{ reduction|number_format(2, ',', ' ') }}
											€</span>
									</div>
								{% endif %}
								<div class="mb-2">Total TTC :
									<span class="fw-bold text-success">{{ (totalAvecPromo + selectedFrais)|number_format(2, ',', ' ') }}
										€</span>
								</div>
							</h3>
							<div class="mb-3">
								<label for="code_promo" class="form-label">Code promo</label>
								<div class="input-group">
									<input type="text" class="form-control" id="code_promo" name="code_promo" placeholder="Saisir un code promo" value="">
									<button type="submit" name="apply_code_promo" value="1" class="btn btn-outline-secondary">Appliquer</button>
								</div>
								{% if codePromo %}
									<div class="form-text text-success">Un code promo est déjà appliqué. Vous pouvez en saisir un autre pour le remplacer.</div>
								{% endif %}
							</div>
							<button type="submit" class="btn btn-success w-100 mt-2">Passer la commande</button>
							<div class="d-flex flex-column flex-md-row gap-2 mt-3">
								<a href="/" class="btn btn-outline-primary flex-fill">
									<i class="bi bi-arrow-left"></i>
									Continuer mes achats</a>
								<a href="{{ path('cart_clear') }}" class="btn btn-outline-danger flex-fill">
									<i class="bi bi-trash"></i>
									Vider le panier</a>
							</div>
						</div>
					</form>
				</div>
			</div>
		{% endif %}
	</div>
{% endblock %}

# Copy to .sync.env and adapt values for your environment.

# SSH target for production server
REMOTE_SSH="konvixadmin@konvix.fr"

# Absolute project path on production server
REMOTE_PROJECT_PATH="/var/www/konvix_ecommerce"

# Where temporary SQL dumps are created on production
REMOTE_TMP_DIR="/tmp"

# Command executed on production server to produce SQL dump to stdout.
# Keep this command safe for your environment (use .my.cnf on VPS if possible).
# Example with explicit credentials:
# REMOTE_DB_DUMP_CMD="mysqldump --single-transaction --quick -u DB_USER -p'DB_PASSWORD' DB_NAME"
REMOTE_DB_DUMP_CMD="mysqldump --single-transaction --quick -u root konvix_ecommerce"

# Command executed locally to import SQL from stdin into dev DB.
# Example: LOCAL_DB_IMPORT_CMD="mysql -u root -p konvix_ecommerce_dev"
LOCAL_DB_IMPORT_CMD="mysql -u root konvix_ecommerce"

# Optional: command executed locally to back up dev DB before import.
# If left empty, no local backup will be generated.
LOCAL_DB_BACKUP_CMD="mysqldump --single-transaction --quick -u root konvix_ecommerce"

# Local uploads path (absolute path recommended)
LOCAL_UPLOADS_PATH="/var/www/konvix_ecommerce/public/uploads"

# Optional local workspace path for downloaded dumps/backups
LOCAL_SYNC_WORK_DIR="/var/www/konvix_ecommerce/tmp/sync-db"
